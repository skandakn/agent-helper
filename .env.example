# Google AI
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash
AGENT_RUNTIME=auto

# Database
POSTGRES_URL=postgresql+asyncpg://user:pass@postgres:5432/hackathon_db
AUTO_CREATE_TABLES=true

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_ENABLED=true

# Auth
JWT_SECRET=change_me_to_random_256bit_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
BACKEND_AUTH_MODE=optional
CLERK_ISSUER_URL=https://your-clerk-instance.clerk.accounts.dev
CLERK_JWKS_URL=
CLERK_AUDIENCE=
CLERK_AUTHORIZED_PARTIES=http://localhost:3000,https://agent-helper-sable.vercel.app
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
USE_SENTENCE_TRANSFORMERS=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Production deployment
# Render backend example: https://agent-helper-api.onrender.com
# Vercel frontend example: https://agent-helper-sable.vercel.app
BACKEND_CORS_ORIGINS=http://localhost:3000,https://agent-helper-sable.vercel.app
# On Vercel set these to your Render backend:
# NEXT_PUBLIC_API_URL=https://your-render-backend.onrender.com
# NEXT_PUBLIC_WS_URL=wss://your-render-backend.onrender.com
